[claude-skin] ▶ PROACTIVE permission card for Bash: python3 << 'PYEOF'
import re

target = '/Users/danilokhury/Apps/Synabun/neural-interface/public/shared/ui-tutorial-steps.js'
replacement = '/tmp/new-workspace-steps.js'

with open(target, 'r') as f:
    lines = f.readlines()

with open(replacement, 'r') as f:
    new_content = f.read()

# Find the start marker: "Step 11: Reveal toolbar + explain workspace"
start_idx = None
for i, line in enumerate(lines):
    if '// ── Step 11: Reveal toolbar + explain workspace' in line:
        start_idx = i
        break

# Find the end marker: "// ── Step 16: Apps menu"
end_idx = None
for i, line in enumerate(lines):
    if '// ── Step 16: Apps menu' in line:
        end_idx = i
        break

if start_idx is None:
    print("ERROR: Could not find start marker")
elif end_idx is None:
    print("ERROR: Could not find end marker")
else:
    print(f"Replacing lines {start_idx+1}-{end_idx} (0-indexed: {start_idx}-{end_idx-1})")
    print(f"Old section: {end_idx - start_idx} lines")
    
    # Also need to renumber subsequent step comments (16+ become 24+)
    new_lines = lines[:start_idx] + [new_content + '\n'] + lines[end_idx:]
    
    with open(target, 'w') as f:
        f.writelines(new_lines)
    
    print("Splice complete!")
    
    # Count total step comments
    with open(target, 'r') as f:
        content = f.read()
    
    step_comments = re.findall(r'// ── Step \d+:', content)
    print(f"\nTotal step comments: {len(step_comments)}")
    for s in step_comments:
        print(f"  {s}")
PYEOF
