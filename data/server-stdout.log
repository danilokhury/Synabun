with open('neural-interface/public/shared/ui-tutorial-steps.js', 'r') as f:
    content = f.read()

with open('/tmp/new-toolbar-steps.js', 'r') as f:
    new_steps = f.read()

start_marker = '  // ── Step 7: Focus Mode'
end_marker = '  // ── Step 11: Reveal toolbar'

start_idx = content.index(start_marker)
end_idx = content.index(end_marker)

result = content[:start_idx] + new_steps + '\n' + content[end_idx:]

with open('neural-interface/public/shared/ui-tutorial-steps.js', 'w') as f:
    f.write(result)

# Count steps for verification
import re
steps = re.findall(r\"id: '([^']+)'\", result)
print(f'Total steps: {len(steps)}')
for i, s in enumerate(steps):
    print(f'  [{i}] {s}')
"

