const fs = require('fs');
const file = 'neural-interface/public/shared/ui-settings.js';
let code = fs.readFileSync(file, 'utf8');

// 1. Extract the browser section from buildSetupTab (lines 686-1108 area)
const browserStart = '        <!-- BROWSER (Playwright) -->';
const browserEnd = '        <!-- COEXISTENCE RULES -->';

const startIdx = code.indexOf(browserStart);
const endIdx = code.indexOf(browserEnd);

if (startIdx === -1) { console.error('Browser start not found'); process.exit(1); }
if (endIdx === -1) { console.error('Browser end not found'); process.exit(1); }

// Extract the browser block (everything between the blank line before browser and coexistence)
const browserBlock = code.substring(startIdx, endIdx).trimEnd();

// 2. Remove browser block from setup tab
code = code.substring(0, startIdx) + code.substring(endIdx);

// 3. Insert browser block into server tab (before the closing </div>\`;)
// The server tab ends with:  </div>\`;  followed by }
const serverClosing = '      </div>\`;\\n}\\n\\nfunction buildSetupTab';
const serverClosingActual = code.indexOf('      </div>\`;\n}\n\nfunction buildSetupTab');
if (serverClosingActual === -1) { console.error('Server tab closing not found'); process.exit(1); }

// Insert before the closing </div> of the server tab
// We need to find the specific closing </div> right before the template literal end
const insertPoint = code.lastIndexOf('      </div>\`;', serverClosingActual + 10);

// Actually, let's find the exact insertion point - right before the closing </div> of the server tab
// The server tab template ends with:
//   </div>
//        </div>\`;
// We want to insert after the backup status div but before the final </div>

const backupStatusEnd = '</div>\\n        <div id=\"sys-backup-status\"';
// Let's use a simpler approach - find 'sys-backup-text' and then find the closing tags after it

const sysBackupText = code.indexOf('id=\"sys-backup-text\"');
if (sysBackupText === -1) { console.error('sys-backup-text not found'); process.exit(1); }

// Find the </div>\\n      </div>\` after sys-backup-text
const afterBackup = code.indexOf('      </div>\`', sysBackupText);
if (afterBackup === -1) { console.error('Server tab end not found'); process.exit(1); }

// Insert the browser section with a divider before the closing </div>
const browserInsertion = '\\n        <div class=\"stg-section-divider\"></div>\\n' + browserBlock + '\\n';

code = code.substring(0, afterBackup) + browserInsertion + code.substring(afterBackup);

fs.writeFileSync(file, code);
console.log('Done - browser settings moved to server tab');
"

