# ═══════════════════════════════════════════════════════════════
# SynaBun — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# THIS IS JUST AN EXAMPLE. DURING THE INSTALLATION PROCESS
# A FRESH .ENV WILL BE AUTOMATICALLY GENERATED
# ═══════════════════════════════════════════════════════════════

# -- SQLite Database --
# Path to the SQLite database file (default: mcp-server/data/memory.db)
# SQLITE_DB_PATH=mcp-server/data/memory.db

# -- Collection Name --
# COLLECTION_NAME=claude_memory

# -- Bridges (auto-managed by Neural Interface) --
# BRIDGE__openclaw__ENABLED=true
# BRIDGE__openclaw__WORKSPACE_PATH=~/.openclaw/workspace
# BRIDGE__openclaw__LAST_SYNC=2026-02-20T12:00:00.000Z

# -- System --
# NEURAL_PORT=3344
# SETUP_COMPLETE=false

# -- Advanced (usually auto-detected) --
# NEURAL_INTERFACE_URL=http://localhost:3344
# MCP_HTTP_PORT=3345
# MEMORY_DATA_DIR=
# DOTENV_PATH=
